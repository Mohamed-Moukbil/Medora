# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/medora?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-super-secret-key-change-in-production"

# SMTP — used for transactional emails (password reset, email verification, contact)
# For Gmail: enable 2FA and create an App Password at https://myaccount.google.com/apppasswords
# Then use your full Gmail address as SMTP_USER and the App Password as SMTP_PASS
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="Medora <noreply@gmail.com>"

# GitHub OAuth
# 1. Go to https://github.com/settings/developers
# 2. Click "New OAuth App"
# 3. Application name: "Medora"
# 4. Homepage URL: http://localhost:3000
# 5. Authorization callback URL: http://localhost:3000/api/auth/callback/github
# 6. Copy Client ID and Client Secret below
# For production: create another OAuth app with your production domain
GITHUB_ID=""
GITHUB_SECRET=""

# Google OAuth (optional)
# 1. Go to https://console.cloud.google.com/apis/credentials
# 2. Create an OAuth 2.0 Client ID
# 3. Application type: "Web application"
# 4. Authorized redirect URIs: http://localhost:3000/api/auth/callback/google
# 5. Copy Client ID and Client Secret below
# For production: add your production domain to authorized redirect URIs
GOOGLE_ID=""
GOOGLE_SECRET=""

# Upstash Redis — required for rate limiting in production (serverless)
# Create a Redis database at https://console.upstash.com and copy the REST URL and token
UPSTASH_REDIS_REST_URL="https://your-region.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-rest-token"

# Contact form — where contact submissions are emailed
CONTACT_EMAIL="admin@medora.dev"
